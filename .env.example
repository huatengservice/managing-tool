# --- Supabase ---
# Public: safe to expose to the browser (RLS is the enforcement boundary).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY. Bypasses RLS entirely. Never expose with a NEXT_PUBLIC_ prefix,
# never import into client components. See PRODUCT_SPEC.md §15.2.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Internal domain for the phone→email mapping (no SMS anywhere, spec §9).
# Production must set this to the app's own domain, e.g. the Vercel
# subdomain — hosted Supabase rejects the .local dev fallback.
NEXT_PUBLIC_PHONE_EMAIL_DOMAIN=phone.huateng.local
# Note: share/QR/invite tokens need no signing secret — they are random
# 32-byte values stored only as SHA-256 hashes in the database.

# --- TapPay (card payments + SaaS subscription billing) ---
# Free sandbox account: https://portal.tappaysdk.com
# Public SDK keys (browser-side card fields):
NEXT_PUBLIC_TAPPAY_APP_ID=
NEXT_PUBLIC_TAPPAY_APP_KEY=
NEXT_PUBLIC_TAPPAY_ENV=sandbox
# SERVER ONLY (never NEXT_PUBLIC): the partner key authorizes real charges.
TAPPAY_PARTNER_KEY=
TAPPAY_MERCHANT_ID=
TAPPAY_ENV=sandbox
