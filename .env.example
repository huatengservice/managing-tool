# --- Supabase ---
# Public: safe to expose to the browser (RLS is the enforcement boundary).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY. Bypasses RLS entirely. Never expose with a NEXT_PUBLIC_ prefix,
# never import into client components. See PRODUCT_SPEC.md §15.2.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret used to sign share/QR tokens (HMAC). Generate: openssl rand -hex 32
TOKEN_SIGNING_SECRET=

# --- NewebPay (藍新金流) ---
# Sandbox: https://cwww.newebpay.com / Production: https://core.newebpay.com
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
NEWEBPAY_API_URL=https://ccore.newebpay.com
# ezPay e-invoice (統一發票) — same vendor family, separate credentials
EZPAY_INVOICE_MERCHANT_ID=
EZPAY_INVOICE_HASH_KEY=
EZPAY_INVOICE_HASH_IV=
EZPAY_INVOICE_API_URL=https://cinv.ezpay.com.tw
